# Influuc — env template. Copy to .env.local and fill. Commit THIS file, never .env.local.
# All secrets are server-side only; NEXT_PUBLIC_* are the only client-exposed values.

# AI
OPENROUTER_API_KEY=

# Research
FIRECRAWL_API_KEY=
EXA_API_KEY=

# Email
RESEND_API_KEY=

# X (Twitter) API
X_BEARER_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# LinkedIn API
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Jobs
TRIGGER_PROJECT_ID=

# Web analytics (public)
NEXT_PUBLIC_GTM_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Monitoring
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
